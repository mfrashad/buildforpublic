<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI for Good Malaysia</title>
<meta name="description" content="Open-source AI projects, community, and advocacy for social impact in Southeast Asia and beyond.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  theme: {
    extend: {
      fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
      colors: {
        brand: { 50:'#ecfdf5', 100:'#d1fae5', 200:'#a7f3d0', 300:'#6ee7b7', 400:'#34d399', 500:'#10b981', 600:'#059669', 700:'#047857', 800:'#065f46', 900:'#064e3b' },
        dark: { 50:'#e8e4de', 100:'#b0a998', 200:'#8a857a', 300:'#666', 400:'#444', 500:'#2a2a2a', 600:'#1f1f1f', 700:'#1a1a1a', 800:'#141414', 900:'#0d0d0d' },
      }
    }
  }
}
</script>
<style>
  html { scroll-behavior: smooth; }
  body { background: #0d0d0d; }
  .gradient-text { background: linear-gradient(135deg, #10b981 0%, #34d399 50%, #6ee7b7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .card-glow:hover { box-shadow: 0 0 30px rgba(16, 185, 129, 0.08); }
  .hero-gradient { background: radial-gradient(ellipse at 50% 0%, rgba(16,185,129,0.08) 0%, transparent 60%); }
  @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
  .animate-in { animation: fadeUp 0.6s ease forwards; }
  .badge { display:inline-block; font-size:0.7rem; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; padding:3px 10px; border-radius:999px; }
</style>
</head>
<body class="text-dark-50 font-sans antialiased">

<!-- Nav -->
<nav class="fixed top-0 w-full z-50 bg-dark-900/80 backdrop-blur-md border-b border-dark-700/50">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#" class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-lg bg-brand-500/20 flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      </div>
      <span class="font-bold text-lg text-dark-50">AI for Good</span>
      <span class="text-[10px] font-semibold text-brand-500 bg-brand-500/10 px-2 py-0.5 rounded-full tracking-wide">.MY</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#community" class="text-sm text-dark-200 hover:text-dark-50 transition">Community</a>
      <a href="#advocacy" class="text-sm text-dark-200 hover:text-dark-50 transition">Advocacy</a>
      <a href="#projects" class="text-sm text-dark-200 hover:text-dark-50 transition">Projects</a>
    </div>
    <a href="#join" class="bg-brand-500 hover:bg-brand-600 text-dark-900 font-semibold text-sm px-5 py-2 rounded-full transition">
      Join Us
    </a>
  </div>
</nav>

<!-- Hero -->
<section class="hero-gradient pt-32 pb-20 px-6">
  <div class="max-w-4xl mx-auto text-center animate-in">
    <div class="badge bg-brand-500/10 text-brand-400 mb-6">Open Source &middot; Community-Driven &middot; Southeast Asia</div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.08] mb-6">
      Building <span class="gradient-text">AI for Good</span>
    </h1>
    <p class="text-lg md:text-xl text-dark-200 max-w-2xl mx-auto mb-10 leading-relaxed">
      Connecting builders and communities for social impact. Open-source projects, advocacy, and a growing community of people using AI to help, not just ship.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="#join" class="bg-brand-500 hover:bg-brand-600 text-dark-900 font-semibold px-7 py-3 rounded-full transition text-base">
        Become a Volunteer &rarr;
      </a>
      <a href="#projects" class="border border-dark-500 hover:border-dark-300 text-dark-100 font-medium px-7 py-3 rounded-full transition text-base">
        View Projects
      </a>
    </div>
  </div>
</section>

<!-- Stats bar -->
<section class="border-y border-dark-700/50 py-8 px-6">
  <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
    <div>
      <div class="text-2xl font-bold text-dark-50">20+</div>
      <div class="text-xs text-dark-300 mt-1">Hackathons & Meetups</div>
